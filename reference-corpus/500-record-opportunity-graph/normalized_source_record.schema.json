{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spinoutu.example/schemas/normalized-source-record-v1.json",
  "title": "Normalized Federated Source Record v1",
  "type": "object",
  "required": [
    "source_record_id",
    "source_system",
    "source_class",
    "source_uri",
    "publisher",
    "retrieved_at",
    "title",
    "raw_text",
    "content_hash",
    "permitted_use",
    "claim_status",
    "ingestion_version",
    "graph_roles",
    "domains"
  ],
  "properties": {
    "source_record_id": {"type": "string", "minLength": 1},
    "source_system": {"type": "string", "minLength": 1},
    "source_class": {"type": "string", "minLength": 1},
    "source_uri": {"type": "string", "minLength": 1},
    "publisher": {"type": "string", "minLength": 1},
    "retrieved_at": {"type": "string", "format": "date-time"},
    "source_modified_at": {"type": ["string", "null"], "format": "date-time"},
    "title": {"type": "string", "minLength": 1},
    "raw_text": {"type": "string"},
    "structured_metadata": {"type": "object"},
    "content_hash": {"type": "string", "minLength": 8},
    "permitted_use": {"enum": ["public", "internal", "restricted", "unknown"]},
    "claim_status": {"enum": ["source_asserted", "verified", "inferred", "disputed", "stale", "unknown"]},
    "review_state": {"enum": ["unreviewed", "machine_reviewed", "human_reviewed", "approved", "held"]},
    "ingestion_version": {"type": "string", "minLength": 1},
    "canonical_subject_candidates": {"type": "array", "items": {"type": "string"}},
    "institution_candidates": {"type": "array", "items": {"type": "string"}},
    "geographies": {"type": "array", "items": {"type": "string"}},
    "graph_roles": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "domains": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "functions": {"type": "array", "items": {"type": "string"}},
    "inputs": {"type": "array", "items": {"type": "string"}},
    "outputs": {"type": "array", "items": {"type": "string"}},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "requirements_satisfied": {"type": "array", "items": {"type": "string"}},
    "deployment_environments": {"type": "array", "items": {"type": "string"}},
    "industry_applications": {"type": "array", "items": {"type": "string"}},
    "readiness_signals": {"type": "array", "items": {"type": "string"}},
    "complementary_components": {"type": "array", "items": {"type": "string"}},
    "substitutes": {"type": "array", "items": {"type": "string"}},
    "rights_status": {"enum": ["available", "licensed", "expired", "public_domain", "restricted", "unknown", "not_applicable"]},
    "commercial_pathways": {"type": "array", "items": {"type": "string"}},
    "evidence_references": {"type": "array", "items": {"type": "string"}},
    "stress_tests": {"type": "array", "items": {"type": "string"}},
    "non_claims": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
