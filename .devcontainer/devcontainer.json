{
  "name": "Airport Opportunity Compiler",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Airport Opportunity Environment",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "python3 compiler/compiler.py",
  "postStartCommand": "bash .devcontainer/start.sh"
}
